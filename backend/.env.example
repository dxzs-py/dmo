# ========================================
# Django 核心配置
# ========================================
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ========================================
# 数据库配置
# ========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=langchain_user
DB_PASSWORD=your-database-password
DB_NAME=langchain

# ========================================
# OpenAI API 配置
# ========================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_STREAMING=True
OPENAI_MAX_TOKENS=

# ========================================
# Tavily 搜索配置
# ========================================
TAVILY_API_KEY=your-tavily-api-key
TAVILY_MAX_RESULTS=5

# ========================================
# 高德地图配置
# ========================================
AMAP_KEY=your-amap-api-key

# ========================================
# 服务器配置
# ========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=True

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=100 MB
LOG_RETENTION=30 days

# ========================================
# CORS 配置
# ========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://www.langchain.cn:8080

# ========================================
# 向量存储配置
# ========================================
VECTOR_STORE_PATH=INDEXES_DIR
VECTOR_STORE_TYPE=faiss
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100

# ========================================
# 文本分块配置
# ========================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ========================================
# 检索器配置
# ========================================
RETRIEVER_SEARCH_TYPE=similarity
RETRIEVER_K=4
RETRIEVER_SCORE_THRESHOLD=0.5
RETRIEVER_FETCH_K=20

# ========================================
# Agent 配置
# ========================================
AGENT_MAX_ITERATIONS=15
AGENT_MAX_EXECUTION_TIME=

# ========================================
# RAG Agent 配置
# ========================================
RAG_AGENT_MAX_ITERATIONS=10
RAG_AGENT_RETURN_SOURCE_DOCUMENTS=True
